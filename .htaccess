DirectoryIndex index.php page/index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Strip trailing slash (except for directories)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} ^(.+)/$
    RewriteRule ^ %1 [R=301,L]

    # Serve existing files and directories directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Map clean URL path to page/<name>.php if the file exists (live root domain/subdomain)
    RewriteCond %{DOCUMENT_ROOT}/page/$1.php -f
    RewriteRule ^([^/]+)$ page/$1.php [L]

    # Map clean URL path to page/<name>.php if the file exists (local subdirectory /hmc/)
    RewriteCond %{DOCUMENT_ROOT}/hmc/page/$1.php -f
    RewriteRule ^([^/]+)$ page/$1.php [L]

    # Map empty root path to page/index.php
    RewriteRule ^$ page/index.php [L]
</IfModule>
